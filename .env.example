# Ayah Studio — Environment Variables

# HuggingFace API token for remote Whisper transcription (ayah detection)
# Get one at https://huggingface.co/settings/tokens
HF_TOKEN=

# Optional: path to ffmpeg binary (defaults to "ffmpeg" in PATH)
# FFMPEG_PATH=/usr/local/bin/ffmpeg

# Optional: path to ffprobe binary (defaults to "ffprobe" in PATH)
# FFPROBE_PATH=/usr/local/bin/ffprobe
